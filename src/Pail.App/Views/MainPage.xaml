<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Pail.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="Left" Modifiers="Menu" Invoked="OnBackKeyboardAcceleratorInvoked"/>
    </Page.KeyboardAccelerators>

    <NavigationView
        x:Name="NavView"
        AlwaysShowHeader="False"
        BackRequested="OnBackRequested"
        IsBackButtonVisible="Visible"
        IsPaneOpen="False"
        IsSettingsVisible="False"
        PaneDisplayMode="LeftCompact"
        SelectionChanged="OnNavigationSelectionChanged">

        <NavigationView.Header>
            <Grid Margin="0,0,0,12">
                <TextBlock Text="Pail" FontSize="28" FontWeight="SemiBold" />
            </Grid>
        </NavigationView.Header>

        <NavigationView.MenuItems>
            <NavigationViewItem x:Name="BucketsNavItem" Content="Buckets" Tag="BucketListPage">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="List" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem x:Name="SettingsNavItem" Content="Settings" Tag="SettingsPage">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Setting" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <Frame x:Name="ContentFrame" Navigated="OnContentFrameNavigated" />
    </NavigationView>
</Page>
